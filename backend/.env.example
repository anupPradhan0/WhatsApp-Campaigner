# ---- Backend environment (set these in Dokploy → application → Environment) ----

# Core
NODE_ENV=production
PORT=3000

# Database (use your managed Mongo or the Dokploy service hostname)
MONGO_URI=mongodb://user:pass@mongodb:27017
DB_NAME=whatsapp-campaigner

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# CORS — MUST be the frontend's public origin (credentials are sent)
CORS_ORIGIN=https://app.your-domain.com

# Rate limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Queue + cache (point at your RabbitMQ / Redis services)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379
WORKER_ENABLED=true
WORKER_SEND_DELAY_MS=50
WORKER_MAX_RETRIES=3
IDEMPOTENCY_TTL_SECONDS=600

# Cloudinary (image uploads) — optional but needed for media campaigns
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email notifications (optional)
EMAIL_USER=
EMAIL_PASS=
EMAIL_RECEIVER=
