{
  "name": "whatsapp-campaigner",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter ./backend run dev\" \"pnpm --filter ./frontend run dev\"",
    "install:all": "pnpm install",
    "build:backend": "pnpm --filter ./backend run build",
    "build:frontend": "pnpm --filter ./frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  }
}
